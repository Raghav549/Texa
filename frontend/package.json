{
  "name": "texa-universe",
  "version": "1.0.0",
  "description": "Texa Universe mobile app with Expo Router, real-time voice rooms, premium UI, commerce, reels, chat, gifts, SVG icon system and production-ready native features.",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start -c",
    "android": "expo run:android",
    "android:device": "expo run:android --device",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "doctor": "expo doctor",
    "check": "tsc --noEmit",
    "clean": "expo start -c",
    "clean:android": "cd android && ./gradlew clean",
    "build:apk:dev": "eas build --platform android --profile development --non-interactive",
    "build:apk:preview": "eas build --platform android --profile preview --non-interactive",
    "build:apk:prod": "eas build --platform android --profile production --non-interactive",
    "build:aab:prod": "eas build --platform android --profile production --non-interactive",
    "build:ipa:prod": "eas build --platform ios --profile production --non-interactive",
    "submit:android": "eas submit --platform android --latest --non-interactive",
    "submit:ios": "eas submit --platform ios --latest --non-interactive",
    "update:prod": "eas update --branch production --message production",
    "update:preview": "eas update --branch preview --message preview",
    "install:expo": "npx expo install",
    "reset:cache": "rm -rf node_modules .expo .turbo && npm install && expo start -c"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.3.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/material-top-tabs": "^6.6.14",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@shopify/flash-list": "1.6.4",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "expo": "~51.0.39",
    "expo-application": "~5.9.1",
    "expo-av": "~14.0.7",
    "expo-blur": "~13.0.3",
    "expo-camera": "~15.0.16",
    "expo-clipboard": "~6.0.3",
    "expo-constants": "~16.0.2",
    "expo-crypto": "~13.0.2",
    "expo-device": "~6.0.2",
    "expo-document-picker": "~12.0.2",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.10",
    "expo-haptics": "~13.0.1",
    "expo-image": "~1.13.0",
    "expo-image-manipulator": "~12.0.5",
    "expo-image-picker": "~15.0.7",
    "expo-linear-gradient": "~13.0.2",
    "expo-linking": "~6.3.1",
    "expo-location": "~17.0.1",
    "expo-media-library": "~16.0.5",
    "expo-notifications": "~0.28.19",
    "expo-print": "~13.0.1",
    "expo-router": "~3.5.24",
    "expo-secure-store": "~13.0.2",
    "expo-sharing": "~12.0.1",
    "expo-splash-screen": "~0.27.7",
    "expo-status-bar": "~1.12.1",
    "expo-system-ui": "~3.0.7",
    "expo-updates": "~0.25.28",
    "expo-web-browser": "~13.0.3",
    "moti": "^0.29.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.2",
    "react-native-mmkv": "^3.1.0",
    "react-native-pager-view": "6.3.0",
    "react-native-qrcode-svg": "^6.3.15",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-tab-view": "^3.5.2",
    "socket.io-client": "^4.8.1",
    "zustand": "^4.5.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.7",
    "@types/react": "~18.2.79",
    "@types/react-native": "^0.73.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~11.0.14",
    "eas-cli": "^15.0.15",
    "typescript": "^5.7.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "enabled": true,
        "exclude": [
          "moti"
        ]
      }
    }
  }
}
