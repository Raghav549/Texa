{
  "name": "texa-universe",
  "version": "1.0.0",
  "description": "Advanced production-ready Expo React Native social commerce creator platform",
  "private": true,
  "main": "expo-router/entry",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "doctor": "npx expo-doctor",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"app/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "lint:fix": "eslint \"app/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"app/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx}\" \"*.json\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx}\" \"*.json\"",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "build:apk:dev": "eas build --platform android --profile development --non-interactive",
    "build:apk:preview": "eas build --platform android --profile preview --non-interactive",
    "build:apk:prod": "eas build --platform android --profile production --non-interactive",
    "build:ipa:prod": "eas build --platform ios --profile production --non-interactive",
    "submit:android": "eas submit --platform android --profile production --non-interactive",
    "submit:ios": "eas submit --platform ios --profile production --non-interactive",
    "update:prod": "eas update --branch production --message \"production update\"",
    "clean": "expo start -c",
    "clean:deep": "rm -rf node_modules .expo .turbo dist android ios && npm install",
    "prepare:prod": "npm run doctor && npm run typecheck && npm run lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@gorhom/bottom-sheet": "^4.6.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.3.1",
    "@react-native-masked-view/masked-view": "0.3.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/material-top-tabs": "^6.6.14",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@shopify/flash-list": "1.6.4",
    "@tanstack/react-query": "^5.66.0",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "expo": "~51.0.39",
    "expo-application": "~5.9.1",
    "expo-av": "~14.0.7",
    "expo-blur": "~13.0.3",
    "expo-camera": "~15.0.16",
    "expo-clipboard": "~6.0.3",
    "expo-constants": "~16.0.2",
    "expo-crypto": "~13.0.2",
    "expo-device": "~6.0.2",
    "expo-document-picker": "~12.0.2",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.10",
    "expo-haptics": "~13.0.1",
    "expo-image": "~1.13.0",
    "expo-image-manipulator": "~12.0.5",
    "expo-image-picker": "~15.0.7",
    "expo-linear-gradient": "~13.0.2",
    "expo-linking": "~6.3.1",
    "expo-local-authentication": "~14.0.1",
    "expo-localization": "~15.0.3",
    "expo-location": "~17.0.1",
    "expo-media-library": "~16.0.5",
    "expo-network": "~6.0.1",
    "expo-notifications": "~0.28.19",
    "expo-print": "~13.0.1",
    "expo-router": "~3.5.24",
    "expo-secure-store": "~13.0.2",
    "expo-sharing": "~12.0.1",
    "expo-splash-screen": "~0.27.7",
    "expo-status-bar": "~1.12.1",
    "expo-system-ui": "~3.0.7",
    "expo-updates": "~0.25.27",
    "expo-web-browser": "~13.0.3",
    "lottie-react-native": "6.7.0",
    "moti": "^0.29.0",
    "react": "18.2.0",
    "react-hook-form": "^7.54.2",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-keyboard-controller": "^1.15.2",
    "react-native-mmkv": "^3.2.0",
    "react-native-pager-view": "6.3.0",
    "react-native-qrcode-svg": "^6.3.15",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-tab-view": "^3.5.2",
    "react-native-toast-message": "^2.2.1",
    "react-native-url-polyfill": "^2.0.0",
    "socket.io-client": "^4.8.1",
    "zustand": "^5.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.9",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.2.79",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "babel-preset-expo": "~11.0.0",
    "eslint": "^9.20.1",
    "eslint-config-expo": "^7.1.2",
    "eslint-config-prettier": "^10.0.1",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.4",
    "prettier": "^3.5.1",
    "typescript": "^5.7.3"
  }
}
