generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql"; url = env("DATABASE_URL") }

enum Role { USER, ADMIN, SUPERADMIN }
enum Level { BRONZE, SILVER, GOLD, PLATINUM, DIAMOND }

model User {
  id            String    @id @default(cuid())
  username      String    @unique @db.VarChar(50)
  fullName      String
  email         String    @unique @db.VarChar(100)
  phone         String?
  password      String
  dob           DateTime
  bio           String    @default("")
  avatarUrl     String?
  role          Role      @default(USER)
  isVerified    Boolean   @default(false)
  followers     String[]
  following     String[]
  coins         Int       @default(300)
  xp            Int       @default(0)
  level         Level     @default(BRONZE)
  createdAt     DateTime  @default(now())
  stories       Story[]
  reels         Reel[]
  sentMessages  Message[] @relation("Sender")
  receivedMsg   Message[] @relation("Receiver")
  seats         Seat[]
  votes         TradeVote[]
  @@index([username])
  @@index([email])
  @@index([level])
}

model Story {
  id        String   @id @default(cuid())
  userId    String
  author    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaUrl  String
  caption   String   @default("")
  expiresAt DateTime @default(now() + interval 24 hours)
  viewers   String[]
  reactions Json     @default("{}")
  createdAt DateTime @default(now())
  @@index([expiresAt])
}

model Reel {
  id         String   @id @default(cuid())
  userId     String
  author     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoUrl   String
  filters    String   @default("{}")
  musicTitle String?
  caption    String   @default("")
  likes      String[]
  comments   String[] @db.Text[]
  views      Int      @default(0)
  createdAt  DateTime @default(now())
  @@index([createdAt(sort: Desc)])
}

model TradeDay {
  id          String      @id @default(cuid())
  date        DateTime    @unique
  isActive    Boolean     @default(true)
  choices     Json
  closedAt    DateTime?
  @@index([isActive])
}

model TradeVote {
  id        String @id @default(cuid())
  tradeId   String
  userId    String
  user      User   @relation(fields: [userId], references: [id])
  choiceId  String
  isInvested Boolean @default(false)
  amount    Int    @default(0)
  trade     TradeDay @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  @@unique([tradeId, userId, choiceId])
}

model VoiceRoom {
  id           String   @id @default(cuid())
  title        String
  hostId       String
  host         User     @relation(fields: [hostId], references: [id])
  isActive     Boolean  @default(true)
  seats        Seat[]
  musicQueue   Json     @default("[]")
  currentTrack String?
  createdAt    DateTime @default(now())
  @@index([isActive])
}

model Seat {
  id        String   @id @default(cuid())
  roomId    String
  room      VoiceRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  isHost    Boolean  @default(false)
  isMuted   Boolean  @default(false)
  isMicOn   Boolean  @default(true)
  handRaised Boolean @default(false)
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String?
  mediaUrl   String?
  status     String   @default("sent") // sent, delivered, seen
  createdAt  DateTime @default(now())
  @@index([senderId, receiverId])
  @@index([createdAt(sort: Desc)])
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String?
  details   String
  createdAt DateTime @default(now())
}
