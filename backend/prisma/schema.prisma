generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum Level {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum MsgStatus {
  SENT
  DELIVERED
  SEEN
}

enum ReportType {
  CONTENT
  USER
  ROOM
}

model User {
  id              String         @id @default(cuid())
  username        String         @unique @db.VarChar(50)
  fullName        String
  email           String         @unique @db.VarChar(100)
  phone           String?
  password        String
  dob             DateTime
  bio             String         @default("")
  avatarUrl       String?
  role            Role           @default(USER)
  isVerified      Boolean        @default(false)
  followers       String[]
  following       String[]
  coins           Int            @default(300)
  xp              Int            @default(0)
  level           Level          @default(BRONZE)
  createdAt       DateTime       @default(now())

  stories         Story[]
  reels           Reel[]

  sentMessages    Message[]      @relation("Sender")
  receivedMsg     Message[]      @relation("Receiver")

  seats           Seat[]
  votes           TradeVote[]

  giftsSent       Gift[]         @relation("GiftSender")
  giftsReceived   Gift[]         @relation("GiftReceiver")

  reports         Report[]       @relation("UserReports")

  comments        Comment[]
  hostedRooms     VoiceRoom[]
  notifications   Notification[]
  pushTokens      PushToken[]

  @@index([username])
  @@index([email])
  @@index([level])
}

model Story {
  id          String    @id @default(cuid())
  userId      String
  author      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  mediaUrl    String
  caption     String    @default("")
  musicTrack  String?

  stickers    Json      @default("{}")
  viewers     String[]
  reactions   Json      @default("{}")

  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([expiresAt])
}

model Reel {
  id           String      @id @default(cuid())
  userId       String
  author       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  videoUrl     String
  filterData   Json        @default("{}")
  musicTrack   String?
  caption      String      @default("")

  likes        String[]
  comments     Comment[]

  views        Int         @default(0)
  createdAt    DateTime    @default(now())

  @@index([createdAt])
}

model Comment {
  id          String      @id @default(cuid())

  reelId      String
  reel        Reel        @relation(fields: [reelId], references: [id], onDelete: Cascade)

  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  text        String
  createdAt   DateTime    @default(now())
}

model TradeDay {
  id          String       @id @default(cuid())

  date        DateTime     @unique
  isActive    Boolean      @default(true)

  choices     Json
  closedAt    DateTime?

  votes       TradeVote[]

  @@index([isActive])
}

model TradeVote {
  id           String       @id @default(cuid())

  tradeId      String
  trade        TradeDay     @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  choiceId     String

  isInvested   Boolean      @default(false)
  amount       Int          @default(0)

  @@unique([tradeId, userId, choiceId])
}

model VoiceRoom {
  id            String      @id @default(cuid())

  title         String
  coverUrl      String?

  hostId        String
  host          User        @relation(fields: [hostId], references: [id], onDelete: Cascade)

  isActive      Boolean     @default(true)

  seats         Seat[]

  chatMessages  Json        @default("[]")
  musicQueue    Json        @default("[]")

  currentTrack  String?
  isPlaying     Boolean     @default(false)

  createdAt     DateTime    @default(now())

  @@index([isActive])
}

model Seat {
  id            String       @id @default(cuid())

  roomId        String
  room          VoiceRoom    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  isHost        Boolean      @default(false)
  isMuted       Boolean      @default(false)
  isSpeaking    Boolean      @default(false)
  handRaised    Boolean      @default(false)
}

model Message {
  id            String        @id @default(cuid())

  senderId      String
  sender        User          @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId    String
  receiver      User          @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  content       String?
  mediaUrl      String?

  status        MsgStatus     @default(SENT)

  createdAt     DateTime      @default(now())

  @@index([senderId, receiverId])
  @@index([createdAt])
}

model Gift {
  id            String       @id @default(cuid())

  fromId        String
  from          User         @relation("GiftSender", fields: [fromId], references: [id], onDelete: Cascade)

  toId          String
  to            User         @relation("GiftReceiver", fields: [toId], references: [id], onDelete: Cascade)

  roomId        String

  type          String
  amount        Int

  createdAt     DateTime     @default(now())
}

model Report {
  id            String        @id @default(cuid())

  reporterId    String
  reporter      User          @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)

  targetType    ReportType
  targetId      String

  reason        String
  status        String        @default("PENDING")

  createdAt     DateTime      @default(now())
}

model ForgotPasswordToken {
  id            String       @id @default(cuid())

  email         String
  token         String       @unique

  expiresAt     DateTime
}

model Announcement {
  id            String       @id @default(cuid())

  title         String
  content       String

  isActive      Boolean      @default(true)

  createdAt     DateTime     @default(now())
}

model Notification {
  id            String       @id @default(cuid())

  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  title         String
  body          String

  type          String
  data          Json?        @default("{}")

  isRead        Boolean      @default(false)

  createdAt     DateTime     @default(now())

  @@index([userId, isRead])
}

model PushToken {
  id            String       @id @default(cuid())

  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  token         String       @unique
  platform      String

  isActive      Boolean      @default(true)

  lastUsed      DateTime     @default(now())
}
