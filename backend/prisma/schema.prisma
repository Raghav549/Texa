datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique @db.VarChar(50)
  fullName      String
  email         String    @unique @db.VarChar(100)
  phone         String?
  password      String
  dob           DateTime
  bio           String    @default("")
  avatarUrl     String?
  isVerified    Boolean   @default(false)
  followers     String[]  @map("followers") @db.StringArray
  following     String[]  @map("following") @db.StringArray
  coins         Int       @default(300)
  xp            Int       @default(0)
  level         String    @default("Bronze")
  createdAt     DateTime  @default(now())
  stories       Story[]
  reels         Reel[]
  messages      Message[] @relation("MessagesAsSender")
  receivedMsg   Message[] @relation("MessagesAsReceiver")
  roomSeats     Seat[]
  tradeVotes    TradeVote[]
  admin         Admin?
}

model Story {
  id        String   @id @default(cuid())
  userId    String
  author    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaUrl  String
  caption   String   @default("")
  expiresAt DateTime @default(now() + interval 24 hours)
  viewers   String[] @db.StringArray
  reactions Int      @default(0)
  createdAt DateTime @default(now())
}

model Reel {
  id          String   @id @default(cuid())
  userId      String
  author      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoUrl    String
  filterData  String   @default("{}")
  musicId     String?
  caption     String   @default("")
  likes       String[] @db.StringArray
  comments    Comment[]
  views       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Comment {
  id        String @id @default(cuid())
  reelId    String
  reel      Reel   @relation(fields: [reelId], references: [id], onDelete: Cascade)
  userId    String
  author    User   @relation(fields: [userId], references: [id])
  text      String
  createdAt DateTime @default(now())
}

model TradeDay {
  id          String      @id @default(cuid())
  date        DateTime    @unique @default(now())
  isActive    Boolean     @default(true)
  choices     Json
  closedAt    DateTime?
  resolvedBy  String?     @ref(User)
  votes       TradeVote[]
}

model TradeVote {
  id        String @id @default(cuid())
  tradeId   String
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  choiceId  String
  isInvested Boolean @default(false)
  amount    Int    @default(0)
  trade     TradeDay @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model VoiceRoom {
  id        String   @id @default(cuid())
  title     String
  hostId    String
  host      User     @relation(fields: [hostId], references: [id])
  isActive  Boolean  @default(true)
  seats     Seat[]
  musicQueue Json   @default("[]")
  currentTrack String?
}

model Seat {
  id        String   @id @default(cuid())
  roomId    String
  room      VoiceRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  isHost    Boolean  @default(false)
  isMuted   Boolean  @default(false)
  isSpeaking Boolean @default(false)
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("MessagesAsSender", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("MessagesAsReceiver", fields: [receiverId], references: [id])
  content    String?
  mediaUrl   String?
  status     String   @default("sent")
  createdAt  DateTime @default(now())
}

model Admin {
  id       String @id @default(cuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id])
  role     String @default("moderator")
}
