{
  "name": "texa-backend",
  "version": "1.0.0",
  "description": "Texa production backend with Express, Prisma, Redis, Socket.IO, BullMQ workers, media processing, Cloudinary, S3, search, security and real-time voice infrastructure.",
  "private": true,
  "type": "commonjs",
  "main": "dist/src/server.js",
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "nodemon",
    "dev:inspect": "nodemon --inspect",
    "build": "npm run clean && npm run db:generate && tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "start:prod": "cross-env NODE_ENV=production node dist/src/server.js",
    "workers": "tsx src/workers/index.ts",
    "workers:dev": "nodemon --watch src --watch prisma --ext ts,json,prisma --exec tsx src/workers/index.ts",
    "workers:prod": "cross-env NODE_ENV=production node dist/src/workers/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo .cache coverage",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:force": "prisma db push --accept-data-loss",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:format": "prisma format",
    "db:validate": "prisma validate",
    "db:status": "prisma migrate status",
    "lint:types": "tsc -p tsconfig.json --noEmit",
    "health": "node -e \"fetch(process.env.HEALTH_URL||'http://localhost:3000/health').then(r=>r.json()).then(console.log).catch(e=>{console.error(e.message);process.exit(1)})\"",
    "ready": "node -e \"fetch(process.env.READY_URL||'http://localhost:3000/ready').then(r=>r.json()).then(console.log).catch(e=>{console.error(e.message);process.exit(1)})\"",
    "prepare:render": "npm ci && npm run build && npm run db:migrate:deploy",
    "prepare:railway": "npm ci && npm run build && npm run db:migrate:deploy",
    "prepare:docker": "npm ci && npm run build",
    "render:build": "npm ci && npm run build",
    "render:start": "npm run start:prod",
    "railway:build": "npm ci && npm run build",
    "railway:start": "npm run start:prod",
    "media:probe": "node -e \"console.log('ffmpeg',require('ffmpeg-static'));console.log('ffprobe',require('ffprobe-static').path)\"",
    "prisma": "prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.744.0",
    "@aws-sdk/s3-request-presigner": "^3.744.0",
    "@prisma/client": "^5.22.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.34.2",
    "cheerio": "^1.0.0",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "meilisearch": "^0.46.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.9",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "rate-limit-redis": "^4.2.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.9",
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "nodemonConfig": {
    "watch": [
      "src",
      "prisma"
    ],
    "ext": "ts,json,prisma",
    "ignore": [
      "dist",
      "node_modules",
      "uploads",
      "tmp",
      "logs",
      "coverage",
      ".turbo",
      ".cache"
    ],
    "exec": "tsx src/server.ts",
    "delay": "300"
  },
  "keywords": [
    "texa",
    "backend",
    "express",
    "prisma",
    "postgresql",
    "redis",
    "socket.io",
    "voice-room",
    "realtime",
    "commerce",
    "media-processing",
    "workers",
    "bullmq",
    "cloudinary",
    "s3"
  ],
  "author": "Texa",
  "license": "UNLICENSED"
}
