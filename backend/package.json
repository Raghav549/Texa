{
  "name": "texa-backend",
  "version": "1.0.0",
  "description": "Texa backend API, realtime sockets, media workers, commerce, reels, stories, rooms, trading and notifications",
  "main": "dist/src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.11.0 <27",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist .turbo .cache coverage",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "build": "npm run clean && npm run db:generate && tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers/media.worker.ts",
    "worker": "node dist/src/workers/media.worker.js",
    "postinstall": "prisma generate",
    "render-build": "npm install && npx prisma generate && npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"lint skipped\"",
    "test": "echo \"No tests configured\""
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/lib-storage": "^3.758.0",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.41.7",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^2.1.35",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.9",
    "nodemailer": "^6.9.16",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mime-types": "^2.1.4",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "prisma": "5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
